<?xml version="1.0" encoding="utf-8"?>
<!--
    앱의 신분증입니다.
    * 인터넷 권한(uses-permission INTERNET)을 일부러 넣지 않았습니다.
      그래서 이 앱은 기술적으로 네트워크를 사용할 수 없습니다.
    * <service> 부분이 "이 앱은 키보드입니다" 라고 폰에 알려주는 핵심입니다.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- 앱 아이콘을 누르면 열리는 설정 화면(= 홈 화면 진입점).
             키보드 설정에서도 이 화면으로 연결됩니다(method.xml의 settingsActivity). -->
        <activity
            android:name=".SettingsActivity"
            android:label="@string/app_name"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault.Light.DarkActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".KoreanImeService"
            android:label="@string/ime_label"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
    </application>

</manifest>
